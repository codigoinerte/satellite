# ── NASA API ──────────────────────────────────────────────────────────────────
# Obtén tu key gratuita en https://api.nasa.gov/
# Usada para eventos espaciales en tiempo real (DONKI + EONET).
# Sin key funciona con DEMO_KEY pero con cuota muy limitada (30 req/hora).
VITE_NASA_API_KEY=DEMO_KEY

# ── APIs externas (sin key, referencia) ───────────────────────────────────────
# Datos TLE/orbitales — fuente oficial de satélites
# CELESTRAK_GP = https://celestrak.org/NORAD/elements/gp.php
#
# Proxy CORS para CelesTrak (gratuito, sin auth)
# ALLORIGINS   = https://api.allorigins.win/raw?url=
#
# Eventos climáticos espaciales (solar flares, geomagnetic storms)
# NASA DONKI   = https://api.nasa.gov/DONKI/notifications
#
# Eventos naturales observados por satélites (incendios, tormentas)
# NASA EONET   = https://eonet.gsfc.nasa.gov/api/v3/events
